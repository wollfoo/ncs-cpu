{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "pid": {
      "type": "integer",
      "minimum": 1,
      "description": "Process ID của GPU miner"
    },
    "miner_type": {
      "type": "string",
      "enum": ["gpu", "GPU"],
      "description": "Loại miner"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "Thời gian sự kiện"
    },
    "event_type": {
      "type": "string",
      "enum": ["mining_started", "mining_stopped", "mining_error", "gpu_temp_update", "hashrate_update", "throttle_request", "stop_request"],
      "description": "Loại sự kiện"
    },
    "data": {
      "type": "object",
      "description": "Dữ liệu bổ sung cho sự kiện",
      "properties": {
        "temperature": {
          "type": "number",
          "minimum": 0,
          "maximum": 120,
          "description": "Nhiệt độ GPU (°C)"
        },
        "hashrate": {
          "type": "number",
          "minimum": 0,
          "description": "Tốc độ hash (H/s)"
        },
        "power_usage": {
          "type": "number",
          "minimum": 0,
          "description": "Công suất tiêu thụ (W)"
        },
        "memory_usage": {
          "type": "number",
          "minimum": 0,
          "maximum": 100,
          "description": "Sử dụng bộ nhớ GPU (%)"
        }
      }
    }
  },
  "required": ["pid", "miner_type", "timestamp", "event_type"],
  "additionalProperties": false
}