{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "pid": {
      "type": "integer",
      "minimum": 1,
      "description": "Process ID của CPU miner"
    },
    "miner_type": {
      "type": "string",
      "enum": ["cpu"],
      "description": "Loại miner"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "Thời gian sự kiện"
    },
    "event_type": {
      "type": "string",
      "enum": ["mining_started", "mining_stopped", "mining_error", "hashrate_update", "throttle_request", "stop_request"],
      "description": "Loại sự kiện"
    },
    "data": {
      "type": "object",
      "description": "Dữ liệu bổ sung cho sự kiện"
    }
  },
  "required": ["pid", "miner_type", "timestamp", "event_type"],
  "additionalProperties": false
}